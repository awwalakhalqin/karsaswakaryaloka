---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';

const milestones = [
  { year: "2020", title: "Berdiri Sejak", desc: "Awal mula kami melayani digitalisasi sistem operasional bisnis di skala lokal." },
  { year: "2021", title: "Layanan Lintas Sektor", desc: "Berhasil meluncurkan solusi khusus untuk sektor kesehatan, logistik, dan retail." },
  { year: "2022", title: "Ekspansi Tim", desc: "Merekrut talenta spesialis di bidang UI/UX dan arsitektur backend skala besar." },
  { year: "Sekarang", title: "Digital Partner", desc: "Kini kami dipercaya sebagai partner strategi digital untuk B2B Enterprise & Startup." }
];
---

<Layout title="Tentang Kami">
  <Navbar />
  
  <main class="page-container">
    <div class="page-header">
      <div class="container text-center">
        <span class="section-label animate-fade-in">Mengenal Lebih Dekat</span>
        <h1 class="page-title animate-fade-in" style="animation-delay: 0.1s;">Transformasi Digital<br/><span class="text-gradient">Dalam Setiap Baris Kode</span></h1>
        <p class="page-subtitle animate-fade-in" style="animation-delay: 0.2s;">
          Kami tidak sekadar membuat aplikasi. Kami memahami masalah bisnis Anda dan mendesain solusi berbasis teknologi.
        </p>
      </div>
    </div>

    <section class="section">
      <div class="container">
        <div class="about-grid">
          <div class="glass-panel about-content animate-fade-in" style="animation-delay: 0.3s;">
            <h2>Visi Kami</h2>
            <p>
              Menjadi mitra strategis terdepan di Indonesia untuk transformasi digital, mengedepankan kualitas, keamanan sistem, dan performa tinggi di segala sektor industri mulai dari f&b, layanan kesehatan, hingga logistik.
            </p>
            <h2 class="mt-8">Misi Kami</h2>
            <ul>
              <li>• Menghadirkan perangkat lunak yang andal (reliable) dan mudah digunakan (usable).</li>
              <li>• Mendorong penerapan arsitektur modern untuk produk yang scalable.</li>
              <li>• Membangun ekosistem teknologi lokal berstandar global.</li>
            </ul>
          </div>

          <div class="timeline animate-fade-in" style="animation-delay: 0.4s;">
            <h3>Perjalanan Karsa Loka</h3>
            <div class="timeline-items">
              {milestones.map((m) => (
                <div class="timeline-item">
                  <div class="timeline-year">{m.year}</div>
                  <div class="timeline-dot"></div>
                  <div class="timeline-content">
                    <h4>{m.title}</h4>
                    <p>{m.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>

  <Footer />
</Layout>

<style>
  .page-container {
    padding-top: var(--nav-height);
  }

  .page-header {
    padding: 6rem 0 3rem;
    position: relative;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center bottom, rgba(59, 130, 246, 0.15) 0%, transparent 60%);
    z-index: -1;
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1.5rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 1.25rem;
    max-width: 700px;
    line-height: 1.6;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .about-content {
    padding: 3rem;
    align-self: start;
  }

  .about-content h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text-main);
  }

  .about-content p, .about-content ul {
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .about-content ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mt-8 {
    margin-top: 2.5rem;
  }

  .timeline {
    padding: 2rem 0;
  }

  .timeline h3 {
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .timeline-items {
    position: relative;
    border-left: 2px solid var(--color-border);
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-dot {
    position: absolute;
    left: -2rem;
    top: 0;
    transform: translateX(-50%);
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--color-primary);
    border: 3px solid var(--color-bg);
    box-shadow: 0 0 10px var(--color-primary);
  }

  .timeline-year {
    font-family: var(--font-display);
    color: var(--color-secondary);
    font-weight: 800;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .timeline-content h4 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .timeline-content p {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
