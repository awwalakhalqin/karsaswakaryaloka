---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import Button from '../../components/Button.astro';
import { portfolios } from '../../data/portfolios';

export async function getStaticPaths() {
  return portfolios.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
---

<Layout title={project.title} description={project.description}>
  <Navbar />
  
  <main class="project-detail">
    <div class="container">
      <div class="breadcrumb">
        <a href="/portfolio">← Kembali ke Portfolio</a>
      </div>

      <div class="project-grid">
        <!-- Gallery Section (Left/Top) -->
        <div class="gallery-section">
          <div class="main-image-container glass-panel">
            <Image 
              id="main-image" 
              src={project.image} 
              alt={project.title} 
              class="main-image" 
              width={1200}
              height={750}
            />
          </div>
          <div class="thumbnail-grid">
            {project.gallery.map((img, idx) => (
              <button class={`thumb-btn ${idx === 0 ? 'active' : ''}`} data-src={img}>
                <Image 
                  src={img} 
                  alt={`${project.title} gallery ${idx}`} 
                  width={200}
                  height={140}
                />
              </button>
            ))}
          </div>
        </div>

        <!-- Info Section (Right/Bottom) -->
        <div class="info-section">
          <div class="project-meta">
            <span class="category-badge">{project.category}</span>
            <span class="meta-item"><strong>Client:</strong> {project.client}</span>
            <span class="meta-item"><strong>Tahun:</strong> {project.year}</span>
          </div>

          <h1 class="project-title">{project.title}</h1>
          
          <div class="project-content">
            <h3>Tentang Proyek</h3>
            <p>{project.content}</p>
          </div>

          <div class="cta-box glass-panel">
            <h4>Tertarik dengan solusi serupa?</h4>
            <p>Diskusikan kebutuhan teknologi bisnis Anda bersama tim ahli kami.</p>
            <Button href="/contact" variant="primary" style="width: 100%;">Mulai Konsultasi Free</Button>
          </div>
        </div>
      </div>
    </div>

    <CTA />
  </main>

  <Footer />
</Layout>

<style>
  .project-detail {
    padding-top: calc(var(--nav-height) + 2rem);
    padding-bottom: 5rem;
  }

  .breadcrumb {
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--color-cyan);
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .breadcrumb a:hover {
    opacity: 0.8;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  /* Gallery Styles */
  .main-image-container {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .thumbnail-grid {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }

  .thumb-btn {
    flex: 0 0 100px;
    height: 70px;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    background: none;
    padding: 0;
    transition: all 0.2s ease;
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-btn.active {
    border-color: var(--color-cyan);
    box-shadow: 0 0 15px rgba(14, 165, 233, 0.3);
  }

  /* Info Section Styles */
  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .category-badge {
    background: rgba(14, 165, 233, 0.1);
    color: var(--color-cyan);
    padding: 0.25rem 1rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid rgba(14, 165, 233, 0.2);
  }

  .meta-item {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .project-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .project-content h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-main);
  }

  .project-content p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  .cta-box {
    padding: 2.5rem;
    text-align: center;
    border: 1px solid rgba(14, 165, 233, 0.2);
  }

  .cta-box h4 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .cta-box p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  @media (max-width: 992px) {
    .project-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

<script>
  function initGallery() {
    const mainImage = document.getElementById('main-image') as HTMLImageElement;
    const thumbBtns = document.querySelectorAll('.thumb-btn');

    thumbBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const newSrc = btn.getAttribute('data-src');
        if (newSrc && mainImage) {
          // Fade effect
          mainImage.style.opacity = '0';
          setTimeout(() => {
            mainImage.src = newSrc;
            mainImage.style.opacity = '1';
          }, 200);

          // Update active state
          thumbBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        }
      });
    });
  }

  // Handle View Transitions
  document.addEventListener('astro:page-load', initGallery);
</script>
